#include <stdio.h>

int main(){
    
    int aux;
    int maior = -1;
    int posicao = 0;
    
    for(int i = 1; i <= 100; i++){
        scanf("%d", &aux);
        
        if(aux > maior){
            maior = aux;
            posicao = i;
        }
    }
    printf("%d\n", maior);
    printf("%d\n", posicao);
    
    return 0;
}
