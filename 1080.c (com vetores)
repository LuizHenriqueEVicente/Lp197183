#include <stdio.h>

int main(){
    
    int vetor[100];
    int maior = 0;
    int posicao = 0;
    
    for(int i = 1; i <= 100; i++){
        scanf("%d", &vetor[i]);
        
        if(vetor[i] > maior){
            maior = vetor[i];
            posicao = i;
        }
    }
    printf("%d\n", maior);
    printf("%d\n", posicao);
    
    return 0;
}
